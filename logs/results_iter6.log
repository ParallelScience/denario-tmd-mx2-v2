        plt.axhline(y=stable_pugh_median, color='green', linestyle=':', linewidth=2, label='Stable Median G/K (' + str(round(stable_pugh_median, 2)) + ')')
    plt.xlabel('Energy Above Hull (eV/atom)', fontsize=12)
