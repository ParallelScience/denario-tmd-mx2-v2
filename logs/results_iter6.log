engineer (to main_cmbagent_chat):

**Code Explanation:**

1. **Data Loading & Merging**: Loads the processed dataset and the uncertainty metrics generated by the ensemble models, merging them on `material_id`.
2. **Data Filtering**: Imputes missing `dos_at_fermi` values using the mean from the training set, then filters out materials with `dos_at_fermi` > 3 standard deviations from the mean to avoid metallic artifacts.
3. **Viability Score Calculation**: Calculates the composite viability score $S$ as the ratio of the mean predicted Pugh's ratio to its standard deviation across the ensemble (adding a small epsilon to avoid division by zero).
4. **Viability Map Generation**: Generates a 2D scatter plot of predicted Pugh's ratio vs. energy above hull, distinguishing between theoretical and experimentally observed materials. It adds reference lines for the stability threshold (0.05 eV/atom) and the median Pugh's ratio of stable materials.
5. **Candidate Ranking**: Ranks the metastable candidates (those lacking original elastic data) based on the viability score $S$ and saves the ranked list to a CSV file.
6. **Prioritization & Output**: Prints the top 10 candidates overall and the top candidates that meet the strict prioritization criteria (`energy_above_hull` $\le$ 0.05 eV/atom and `theoretical` == True).
7. **Sensitivity Check**: Performs a leave-one-metal-out sensitivity check on the top 10 candidates by comparing the ensemble prediction with the Leave-One-Group-Out (LOGO) cross-validation prediction (where the candidate's metal was excluded from training), printing the absolute differences.

**Python Code:**

```python
import sys
import os
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from datetime import datetime
import joblib

plt.rcParams['text.usetex'] = False

def main():
    data_dir = "data"
    
    # Load datasets
    df_path = os.path.join(data_dir, "processed_tmd_data.csv")
    unc_path = os.path.join(data_dir, "uncertainty_metrics.csv")
    
    df = pd.read_csv(df_path)
    df_unc = pd.read_csv(unc_path)
    
    # Merge uncertainty metrics
    df = df.merge(df_unc, on='material_id')
    
    # Load ensemble model to get dos_mean
    ensemble_path = os.path.join(data_dir, "ensemble_models.joblib")
    ensemble_data = joblib.load(ensemble_path)
    dos_mean = ensemble_data['dos_mean']
    
    # Impute missing dos_at_fermi
    df['dos_at_fermi'] = df['dos_at_fermi'].fillna(dos_mean)
    
    # Filter out dos_at_fermi > 3 std from mean
    dos_std = df['dos_at_fermi'].std()
    dos_threshold = dos_mean + 3 * dos_std
    initial_count = len(df)
    df = df[df['dos_at_fermi'] <= dos_threshold].copy()
    filtered_count = len(df)
    print("Filtered out " + str(initial_count - filtered_count) + " materials with dos_at_fermi > 3 std from mean (" + str(round(dos_threshold, 4)) + ").")
    print("Total materials remaining: " + str(filtered_count))
    
    # Calculate composite viability score S
    epsilon = 1e-8
    df['viability_score'] = df['mean_pred_pugh_ratio'] / (df['std_pred_pugh_ratio'] + epsilon)
    
    # Generate 2D probability map (Scatter plot)
    timestamp = str(int(datetime.now().timestamp()))
    plt.figure(figsize=(10, 8))
    
    mask_theo = (df['theoretical'] == True) | (df['theoretical'] == 1)
    mask_exp = (df['theoretical'] == False) | (df['theoretical'] == 0)
    
    plt.scatter(df.loc[mask_theo, 'energy_above_hull'], df.loc[mask_theo, 'mean_pred_pugh_ratio'], 
                c='blue', label='Theoretical (Unobserved)', alpha=0.7, edgecolors='k', s=60)
    plt.scatter(df.loc[mask_exp, 'energy_above_hull'], df.loc[mask_exp, 'mean_pred_pugh_ratio'], 
                c='orange', label='Experimental (Observed)', alpha=0.7, edgecolors='k', s=60)
    
    plt.axvline(x=0.05, color='red', linestyle='--', linewidth=2, label='Stability Threshold (0.05 eV/atom)')
    
    stable_mask = ((df['is_stable'] == True) | (df['is_stable'] == 1)) & df['pugh_ratio'].notna()
    stable_pugh_median = df.loc[stable_mask, 'pugh_ratio'].median()
    if pd.notna(stable_pugh_median):
        plt.axhline(y=stable_pugh_median, color='green', linestyle=':', linewidth=2, label='Stable Median G/K (' + str(round(stable_pugh_median, 2)) + ')')
    
    plt.xlabel('Energy Above Hull (eV/atom)', fontsize=12)
    plt.ylabel('Predicted Pugh\'s Ratio (G/K)', fontsize=12)
    plt.title('Viability Map: Predicted Pugh\'s Ratio vs. Thermodynamic Stability', fontsize=14)
    plt.legend(fontsize=11)
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    
    plot_filename = "viability_map_1_" + timestamp + ".png"
    plot_path = os.path.join(data_dir, plot_filename)
    plt.savefig(plot_path, dpi=300)
    plt.close()
    print("Viability map saved to " + plot_path)
    
    # Rank candidates
    # Candidates are those without original elastic data (pugh_ratio is NaN)
    candidates = df[df['pugh_ratio'].isna()].copy()
    
    # Sort by viability score descending
    candidates = candidates.sort_values(by='viability_score', ascending=False)
    
    # Save ranked candidates
    ranked_path = os.path.join(data_dir, "ranked_candidates.csv")
    candidates.to_csv(ranked_path, index=False)
    print("Ranked candidates saved to " + ranked_path)
    
    # Print top 10 candidates overall
    top_10 = candidates.head(10)
    print("\n--- Top 10 Ranked Metastable Candidates (Overall) ---")
    print(f"{'Rank':<5} | {'Formula':<10} | {'Phase':<15} | {'E_hull (eV)':<12} | {'Pred G/K':<10} | {'Uncertainty':<12} | {'Score S':<10} | {'Theoretical'}")
    print("-" * 105)
    for i, (_, row) in enumerate(top_10.iterrows(), 1):
        phase_cols = [c for c in df.columns if c.startswith('phase_') and row[c] == 1]
        phase_str = phase_cols[0].replace('phase_', '') if phase_cols else 'Unknown'
        print(f"{i:<5} | {row['formula']:<10} | {phase_str:<15} | {row['energy_above_hull']:<12.4f} | {row['mean_pred_pugh_ratio']:<10.4f} | {row['std_pred_pugh_ratio']:<12.4f} | {row['viability_score']:<10.4f} | {row['theoretical']}")
        
    # Print top prioritized candidates
    prioritized = candidates[(candidates['energy_above_hull'] <= 0.05) & ((candidates['theoretical'] == True) | (candidates['theoretical'] == 1))]
    print("\n--- Top Prioritized Candidates (E_hull <= 0.05 & Theoretical) ---")
    if len(prioritized) > 0:
        print(f"{'Rank':<5} | {'Formula':<10} | {'Phase':<15} | {'E_hull (eV)':<12} | {'Pred G/K':<10} | {'Uncertainty':<12} | {'Score S':<10}")
        print("-" * 90)
        for i, (_, row) in enumerate(prioritized.head(10).iterrows(), 1):
            phase_cols = [c for c in df.columns if c.startswith('phase_') and row[c] == 1]
            phase_str = phase_cols[0].replace('phase_', '') if phase_cols else 'Unknown'
            print(f"{i:<5} | {row['formula']:<10} | {phase_str:<15} | {row['energy_above_hull']:<12.4f} | {row['mean_pred_pugh_ratio']:<10.4f} | {row['std_pred_pugh_ratio']:<12.4f} | {row['viability_score']:<10.4f}")
    else:
        print("No candidates meet the strict prioritization criteria.")
        
    # Leave-one-metal-out sensitivity check
    print("\n--- Leave-One-Metal-Out Sensitivity Check for Top 10 Candidates ---")
    print(f"{'Formula':<10} | {'Metal':<6} | {'Ensemble Pred':<15} | {'LOGO CV Pred':<15} | {'Absolute Diff':<15}")
    print("-" * 68)
    for _, row in top_10.iterrows():
        diff = abs(row['mean_pred_pugh_ratio'] - row['cv_pred_pugh_ratio'])
        print(f"{row['formula']:<10} | {row['metal']:<6} | {row['mean_pred_pugh_ratio']:<15.4f} | {row['cv_pred_pugh_ratio']:<15.4f} | {diff:<15.4f}")
    
    mean_diff = np.mean([abs(row['mean_pred_pugh_ratio'] - row['cv_pred_pugh_ratio']) for _, row in top_10.iterrows()])
    print("-" * 68)
    print("Mean Absolute Difference for Top 10: " + str(round(mean_diff, 4)))

if __name__ == '__main__':
    main()
