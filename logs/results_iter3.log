    plt.close()
    print('SHAP interaction plot saved to ' + interaction_plot_path)
    ni_all_df['pred_proba'] = rf_model.predict_proba(X_ni_all)[:, 1]
    print('\nNi-based TMDs Analysis (All Ni-based samples in dataset):')
