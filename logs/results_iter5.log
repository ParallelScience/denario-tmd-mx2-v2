    continuous_cols = ['d_band_filling', 'en_difference', 'M_soc_proxy', 'c_a_ratio', 'bond_radius_sum', 'dos_at_fermi', 'volume_per_atom', 'formation_energy_per_atom', 'band_gap', 'efermi', 'total_magnetization']
