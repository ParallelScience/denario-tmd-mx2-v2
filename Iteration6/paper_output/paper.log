| 6 | WS$_2$ | 1T | 0.0074 | 0.7610 | 0.0052 | 146.1045 | True |
| 7 | MoS$_2$ | 1T | 0.0037 | 0.7243 | 0.0052 | 138.0190 | True |
| 8 | TaSe$_2$ | 2H | 0.0000 | 0.6455 | 0.0048 | 135.1797 | False |
